APP_NAME=PieAgency API
ENVIRONMENT=development
API_PREFIX=/api
FRONTEND_ORIGIN=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
COHERE_API_KEY=
COHERE_MODEL=command-a-03-2025
SUPABASE_URL=
SUPABASE_SECRET_KEY=
# Legacy fallback if you still use the old API keys tab:
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_CONTACT_TABLE=contact_requests
ADMIN_EMAILS=
MAKUTA_BASE_URL=
MAKUTA_API_VERSION=v1
MAKUTA_APP_TOKEN=
MAKUTA_USER_TOKEN=
MAKUTA_LOGIN_URL=
MAKUTA_LOGIN_IDENTITY=
MAKUTA_LOGIN_PASSWORD=
MAKUTA_LOGIN_IDENTITY_FIELD=login
MAKUTA_LOGIN_PASSWORD_FIELD=password
MAKUTA_WALLET_ID=
MAKUTA_WALLET_OPERATION=CREDIT
# Optional override if you want a full URL instead of BASE_URL + API_VERSION:
MAKUTA_TRANSACTION_URL=
# Optional transaction status URL, example:
# https://api.example.com/v1/transactions/{transaction_id}
MAKUTA_STATUS_URL_TEMPLATE=
MAKUTA_STATUS_HTTP_METHOD=GET
MAKUTA_SUPPORTED_CURRENCIES=XOF
# Format: code:label,code:label
MAKUTA_OPERATOR_OPTIONS=
MAKUTA_REQUEST_TIMEOUT_SECONDS=20
MAKUTA_MERCHANT_LABEL=PieAgency
