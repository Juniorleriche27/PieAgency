APP_NAME=PieAgency API
ENVIRONMENT=development
API_PREFIX=/api
FRONTEND_ORIGIN=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
COHERE_API_KEY=
COHERE_MODEL=command-a-03-2025
SUPABASE_URL=
SUPABASE_SECRET_KEY=
# Legacy fallback if you still use the old API keys tab:
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_CONTACT_TABLE=contact_requests
ADMIN_EMAILS=
MAKETOU_BASE_URL=https://api.maketou.net
MAKETOU_API_KEY=
# Optional override if you want a full checkout URL:
MAKETOU_CHECKOUT_URL=
# Optional override if you want a full cart status URL template:
# https://api.maketou.net/api/v1/stores/cart/{cart_id}
MAKETOU_CART_STATUS_URL_TEMPLATE=
# Generic free-price product for payments agreed with clients:
MAKETOU_DEFAULT_PRODUCT_DOCUMENT_ID=
# Optional per-service override: service-slug:productDocumentId,service-slug:productDocumentId
MAKETOU_SERVICE_PRODUCTS=
# Optional return URL after payment. Default: FRONTEND_ORIGIN/paiement?checkout=return
MAKETOU_REDIRECT_URL=
MAKETOU_DISPLAY_CURRENCY=XOF
MAKETOU_REQUEST_TIMEOUT_SECONDS=20
MAKETOU_MERCHANT_LABEL=PieAgency
